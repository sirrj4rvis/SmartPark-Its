{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "SmartPark ITS — Service Overview",
  "tags": ["smartpark"],
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request rate (req/s)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 1 } },
      "targets": [
        { "expr": "sum(rate(smartpark_http_requests_total[1m]))", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error rate (5xx %)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ] }
        }
      },
      "targets": [
        { "expr": "sum(rate(smartpark_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(smartpark_http_requests_total[5m])), 0.001)", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "p95 latency",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(smartpark_http_request_duration_seconds_bucket[5m])) by (le))", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p99 latency",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(smartpark_http_request_duration_seconds_bucket[5m])) by (le))", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request rate by endpoint",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10, "showPoints": "never" } } },
      "targets": [
        { "expr": "sum(rate(smartpark_http_requests_total[1m])) by (endpoint)", "legendFormat": "{{endpoint}}", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 5, "showPoints": "never" } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(smartpark_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(smartpark_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(smartpark_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Responses by status code",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "stacking": { "mode": "normal" }, "fillOpacity": 25, "showPoints": "never" } } },
      "targets": [
        { "expr": "sum(rate(smartpark_http_requests_total[1m])) by (status)", "legendFormat": "{{status}}", "refId": "A" }
      ]
    }
  ]
}
